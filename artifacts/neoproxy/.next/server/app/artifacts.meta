{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/artifacts/layout,_N_T_/artifacts/page,_N_T_/artifacts"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/artifacts/__PAGE__",
    "/artifacts",
    "/_index",
    "/_head"
  ]
}